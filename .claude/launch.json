{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "sleeper-ffm-backend",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "sffm", "serve", "--port", "8001"],
      "port": 8001
    },
    {
      "name": "sleeper-ffm-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev", "--", "--port", "5173", "--host"],
      "port": 5173
    }
  ]
}

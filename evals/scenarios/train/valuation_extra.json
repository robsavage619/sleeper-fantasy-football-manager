              "player_id": "n",
              "name": "n",
              "position": "RB",
              "age": 25,
              "current_fpar": 100,
              "is_taxi": false
            }
          }
        }
      },
      "checks": [
        {
          "type": "ratio",
          "case_a": "taxi",
          "case_b": "non_taxi",

{
  "scenarios": [
    {
      "id": "valuation.age_monotonic_qb",
      "tier": 1,
      "engine": "dynasty_value",
      "rationale": "QB variant of the age-monotonicity invariant.",
      "inputs": {
        "cases": {
          "young": {
            "kind": "player",
            "player": {
              "player_id": "y",
              "name": "y",
              "position": "QB",
              "age": 23,
              "current_fpar": 50,
              "is_taxi": false
            }
          },
          "old": {
            "kind": "player",
            "player": {
              "player_id": "o",
              "name": "o",
              "position": "QB",
              "age": 33,
              "current_fpar": 50,
              "is_taxi": false
            }
          }
        }
      },
      "checks": [
        {
          "type": "compare",
          "left": "young.value",
          "op": ">",
          "right": "old.value"
        }
      ]
    },

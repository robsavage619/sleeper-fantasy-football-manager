            "give_asset": {"asset_id": "p3", "kind": "player", "label": "Fair RB", "position": "RB", "value": 130},
            "receive_asset": {"asset_id": "p4", "kind": "player", "label": "Fair WR", "position": "WR", "value": 130},
            "sweetener": null
          }
        }
      },
      "checks": [
        {"type": "range", "case": "base", "field": "score", "min": 54, "max": 85}
      ]
    },
    {
      "id": "trade.sweetener_monotonic",
      "tier": 1,
      "engine": "trade_acceptance",
      "rationale": "Adding a pick sweetener to an identical offer must never lower the acceptance score.",
      "inputs": {
        "cases": {
          "without_sweetener": {
            "my_dossier": {"roster_id": 1, "league_size": 10},
            "partner": {"roster_id": 2, "league_size": 10, "contention_label": "OPENING"},
            "history": {"roster_id": 2, "trade_count": 5, "approachability": "TYPICAL"},
            "give_asset": {"asset_id": "p5", "kind": "player", "label": "Give RB", "position": "RB", "value": 100},
            "receive_asset": {"asset_id": "p6", "kind": "player", "label": "Target WR", "position": "WR", "value": 95},
            "sweetener": null
          },
          "with_sweetener": {
            "my_dossier": {"roster_id": 1, "league_size": 10},
            "partner": {"roster_id": 2, "league_size": 10, "contention_label": "OPENING"},
            "history": {"roster_id": 2, "trade_count": 5, "approachability": "TYPICAL"},
            "give_asset": {"asset_id": "p5", "kind": "player", "label": "Give RB", "position": "RB", "value": 100},
            "receive_asset": {"asset_id": "p6", "kind": "player", "label": "Target WR", "position": "WR", "value": 95},
            "sweetener": {"asset_id": "2027_R3", "kind": "pick", "label": "2027 R3", "position": null, "value": 15}
          }
        }
      },
      "checks": [
        {"type": "compare", "left": "with_sweetener.score", "op": ">", "right": "without_sweetener.score"}
      ]
    }
  ]
}

{
  "scenarios": [
    {
      "id": "trade.fleece_low_acceptance",
      "tier": 1,
      "engine": "trade_acceptance",
      "rationale": "A -190 FPAR margin for the partner must land in the LOW bucket.",
      "inputs": {
        "cases": {
          "base": {
            "my_dossier": {"roster_id": 1, "league_size": 10},
            "partner": {"roster_id": 2, "league_size": 10, "contention_label": "OPEN"},
            "history": null,
            "give_asset": {"asset_id": "p1", "kind": "player", "label": "Scrub RB", "position": "RB", "value": 60},
            "receive_asset": {"asset_id": "p2", "kind": "player", "label": "Stud RB", "position": "RB", "value": 250},
            "sweetener": null
          }
        }
      },
      "checks": [
        {"type": "range", "case": "base", "field": "score", "min": 5, "max": 53},
        {"type": "exact", "case": "base", "field": "confidence", "value": "LOW"},
        {"type": "approx", "case": "base", "field": "margin", "value": -190.0, "tol": 5.0}
      ]
    },
    {
      "id": "trade.fair_swap_mid",
      "tier": 1,
      "engine": "trade_acceptance",
      "rationale": "An even-value swap into a real need should land in the MED/HIGH band, not LOW.",
      "inputs": {
        "cases": {
          "base": {
            "my_dossier": {"roster_id": 1, "league_size": 10},
            "partner": {"roster_id": 2, "league_size": 10, "contention_label": "ASCENDING"},

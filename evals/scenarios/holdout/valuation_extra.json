      ]
    },
    {
      "id": "valuation.pick_add_monotonic_fallback",
      "tier": 1,
      "engine": "dynasty_value",
      "rationale": "Adding a pick priced via the fallback (no market) branch still strictly increases total value.",
      "inputs": {
        "cases": {
          "without_extra": {
            "kind": "pick_list",
            "mode": "sum",
            "picks": [
              {
                "pick": {
                  "season": "2026",
                  "round": 1,
                  "original_owner_id": 1,
                  "current_owner_id": 1,
                  "class_strength": 1.0
                },
                "market_value": 180
              }
            ]
          },
          "with_extra": {
            "kind": "pick_list",
            "mode": "sum",
            "picks": [
              {
                "pick": {
                  "season": "2026",
                  "round": 1,
                  "original_owner_id": 1,
                  "current_owner_id": 1,
                  "class_strength": 1.0
                },
                "market_value": 180
              },
              {
                "pick": {
                  "season": "2028",
                  "round": 4,
                  "original_owner_id": 1,
                  "current_owner_id": 1,
                  "class_strength": 1.0
                },
                "market_value": null
              }
            ]
          }
        }
      },
      "checks": [
        {
          "type": "compare",
          "left": "with_extra.value",
          "op": ">",
          "right": "without_extra.value"
        }
      ]
    },
